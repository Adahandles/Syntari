# Syntari Environment Variables (Example)
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# AI Integration (for v0.4+)
# AI_API_KEY=your_api_key_here
# AI_PROVIDER=openai

# Web REPL Configuration
# WEB_REPL_PORT=8080
# WEB_REPL_HOST=localhost

# Web REPL Admin Authentication
# ADMIN_AUTH_TOKEN=your_secure_random_token_here
# Generate a secure token with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# Development Settings
# DEBUG=false
# LOG_LEVEL=INFO

# Network Security
# ALLOW_PRIVATE_IPS=false
# MAX_REQUEST_SIZE=1048576

# Note: All sensitive data should be stored in .env, not in code
