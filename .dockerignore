# Syntari Docker Ignore File
# Prevents unnecessary files from being copied to Docker images

# Git
.git/
.github/
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Documentation (build output)
docs/_build/

# Logs and databases
*.log
*.db
*.sqlite

# Environment files
.env
.env.local
*.pem
*.key

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.sbc

# OS specific
Thumbs.db
Desktop.ini
