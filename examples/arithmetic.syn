// Arithmetic operations example
let a = 10
let b = 5

print("Addition:", a + b)
print("Subtraction:", a - b)
print("Multiplication:", a * b)
print("Division:", a / b)
print("Modulo:", a % b)

// Precedence test
let result = 2 + 3 * 4
print("2 + 3 * 4 =", result)

// Parentheses
let result2 = (2 + 3) * 4
print("(2 + 3) * 4 =", result2)
